# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Meta WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# MySQL Database
DB_CONNECTION_STRING=server=localhost;port=3306;database=sellbotlk;user=root;password=your_db_password_here;Allow User Variables=true;

# JWT Authentication
JWT_SECRET=your_minimum_256_bit_secret_key_here_at_least_32_characters

# Admin Dashboard Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Payment Bank Details (shown to customers in order confirmation)
PAYMENT_BANK_NAME=Bank of Ceylon
PAYMENT_ACCOUNT_NUMBER=0000000000
PAYMENT_ACCOUNT_HOLDER=SellBot.lk

# Business Owner WhatsApp
OWNER_PHONE=+94771234567

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development